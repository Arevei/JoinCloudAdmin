# Cloudflare Tunnel (Remote Access)
# API token needs: Account → Cloudflare Tunnel (Edit); Zone → DNS (Edit)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_BASE_DOMAIN=joincloud.cloud

# Public share link signing (HMAC); must match JOINCLOUD_SIGNING_SECRET on desktop app
SIGNING_SECRET=   # Random 32+ char secret, shared with desktop app
